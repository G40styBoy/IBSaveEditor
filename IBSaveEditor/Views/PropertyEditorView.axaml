<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IBSaveEditor.ViewModels"
             x:Class="IBSaveEditor.Views.PropertyEditorView"
             x:DataType="vm:NodeViewModel">
  <Panel>

    <!-- Nothing selected -->
    <TextBlock IsVisible="{Binding $parent[UserControl].DataContext, Converter={x:Static ObjectConverters.IsNull}}"
               Text="Select a property to edit."
               Foreground="#415A77" FontSize="13"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

    <ScrollViewer IsVisible="{Binding $parent[UserControl].DataContext, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Padding="16,16,16,16">
      <StackPanel Spacing="0">

        <!-- Header: name only, no badge -->
        <StackPanel Spacing="6" Margin="0,0,0,20">
          <TextBlock Text="{Binding DisplayName}" Foreground="#E0E1DD" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>

        <Border Classes="divider" Margin="0,0,0,20"/>

        <!-- ═══ PRIMITIVE ═══════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsPrimitive}" Spacing="8">
          <DockPanel>
            <TextBlock Classes="field-label" Text="VALUE" FontSize="13"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Classes="log-clear-btn" HorizontalAlignment="Right"
                    IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsNotBool}}"
                    Content="Copy" Click="OnCopyValueClick"
                    Foreground="#E0E1DD" Background="#415A77" Padding="8,2"/>
          </DockPanel>

          <!-- FName label (shown when string starts with _ini) -->
          <TextBlock x:Name="FNameLabel"
                     IsVisible="False"
                     Text="fname  /  references game ini files"
                     Foreground="#778DA9" FontSize="10" FontStyle="Italic"/>

          <!-- Bool -->
          <ToggleSwitch x:Name="BoolToggle"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsBool}}"
              IsChecked="False"
              OnContent="true" OffContent="false"
              IsCheckedChanged="OnBoolToggleChanged"/>

          <!-- Int -->
          <TextBox x:Name="IntBox"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsInt}}"
              Classes="prop-input"
              MinWidth="60" MaxWidth="500"
              HorizontalAlignment="Left"
              LostFocus="OnIntBoxLostFocus"
              KeyDown="OnNumericKeyDown"
              TextChanged="OnNumericTextChanged"/>

          <!-- Byte -->
          <TextBox x:Name="ByteBox"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsByte}}"
              Classes="prop-input"
              MinWidth="60" MaxWidth="500"
              HorizontalAlignment="Left"
              LostFocus="OnByteBoxLostFocus"
              KeyDown="OnNumericKeyDown"
              TextChanged="OnNumericTextChanged"/>

          <!-- Float -->
          <TextBox x:Name="FloatBox"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsFloat}}"
              Classes="prop-input"
              MinWidth="60" MaxWidth="500"
              HorizontalAlignment="Left"
              LostFocus="OnFloatBoxLostFocus"
              KeyDown="OnNumericKeyDown"
              TextChanged="OnNumericTextChanged"/>

          <!-- String -->
          <TextBox x:Name="StringBox"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsString}}"
              Classes="prop-input"
              MinWidth="60"
              HorizontalAlignment="Left"
              LostFocus="OnStringBoxLostFocus"
              TextChanged="OnStringTextChanged"/>

          <!-- Name -->
          <TextBox x:Name="NameBox"
              IsVisible="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsName}}"
              Classes="prop-input"
              MinWidth="60"
              HorizontalAlignment="Left"
              LostFocus="OnStringBoxLostFocus"
              TextChanged="OnStringTextChanged"/>
        </StackPanel>

        <!-- ═══ ENUM ═════════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsEnum}" Spacing="12">
          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="ENUM TYPE" FontSize="13"/>
            <TextBox x:Name="EnumTypeBox" Classes="prop-input"
                     MinWidth="60" HorizontalAlignment="Left"
                     LostFocus="OnEnumTypeLostFocus"
                     TextChanged="OnStringTextChanged"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="ENUM VALUE" FontSize="13"/>
            <TextBox x:Name="EnumValueBox" Classes="prop-input"
                     MinWidth="60" HorizontalAlignment="Left"
                     LostFocus="OnEnumValueLostFocus"
                     TextChanged="OnStringTextChanged"/>
          </StackPanel>
        </StackPanel>

        <!-- ═══ STRUCT ═══════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsStruct}" Spacing="4">
          <DockPanel Margin="0,0,0,10">
            <TextBlock Classes="field-label" Text="MEMBERS" FontSize="13"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Classes="add-item-btn" HorizontalAlignment="Right"
                    Content="+ Add Member" Click="OnAddMemberClick"/>
          </DockPanel>

          <!-- Struct type picker -->
          <Border Classes="type-picker" x:Name="StructTypePickerPanel" IsVisible="False" Margin="0,0,0,10">
            <StackPanel Spacing="8">
              <DockPanel>
                <TextBlock Classes="field-label" Text="MEMBER NAME" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <Button Classes="array-remove-btn" Content="✕" HorizontalAlignment="Right"
                        Click="OnCancelStructAdd" Foreground="#415A77"/>
              </DockPanel>
              <TextBox x:Name="StructMemberNameBox" Classes="prop-input" Watermark="e.g. MyProperty"/>
              <TextBlock Classes="field-label" Text="SELECT TYPE" Margin="0,6,0,0"/>
              <WrapPanel Orientation="Horizontal">
                <Button Classes="type-choice-btn" Content="int"    Tag="int"    Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="float"  Tag="float"  Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="bool"   Tag="bool"   Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="byte"   Tag="byte"   Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="string" Tag="string" Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="name"   Tag="name"   Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="struct" Tag="struct" Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="array"  Tag="array"  Click="OnStructTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="enum"   Tag="enum"   Click="OnStructTypeChosen" Margin="0,0,6,6"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <ItemsControl ItemsSource="{Binding Children}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:NodeViewModel">
                <Border Padding="0,6" BorderBrush="#1B263B" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="Auto,8,*,8,Auto,4,Auto">
                    <!-- Type badge (hidden when IsIni : fname badge takes over) -->
                    <Border Grid.Column="0" Classes="badge"
                            IsVisible="{Binding ShowBadgeNonIni}"
                            Classes.badge-int="{Binding TypeHint,    Converter={x:Static vm:TypeHintConverters.IsInt}}"
                            Classes.badge-float="{Binding TypeHint,  Converter={x:Static vm:TypeHintConverters.IsFloat}}"
                            Classes.badge-bool="{Binding TypeHint,   Converter={x:Static vm:TypeHintConverters.IsBool}}"
                            Classes.badge-string="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsString}}"
                            Classes.badge-byte="{Binding TypeHint,   Converter={x:Static vm:TypeHintConverters.IsByte}}"
                            Classes.badge-struct="{Binding IsStruct}"
                            Classes.badge-array="{Binding IsArray}"
                            Classes.badge-enum="{Binding IsEnum}">
                      <TextBlock Text="{Binding TypeHint}" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <!-- FName badge -->
                    <Border Grid.Column="0" Classes="badge badge-fname"
                            IsVisible="{Binding ShowBadgeIni}">
                      <TextBlock Text="fname" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <!-- Member name -->
                    <TextBlock Grid.Column="2" Classes="prop-label" Text="{Binding DisplayName}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="4" Classes="array-remove-btn" Content="⧉"
                            Tag="{Binding}" Click="OnDuplicateMemberClick" Foreground="#415A77"/>
                    <Button Grid.Column="6" Classes="array-remove-btn" Content="✕"
                            Tag="{Binding}" Click="OnRemoveMemberClick"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- ═══ ARRAY ════════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsArray}" Spacing="4">
          <DockPanel Margin="0,0,0,10">
            <TextBlock Classes="field-label" Text="ITEMS" FontSize="13"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Classes="add-item-btn" HorizontalAlignment="Right"
                    IsVisible="{Binding !IsFixedArray}"
                    Content="+ Add Item" Click="OnAddItemClick"/>
          </DockPanel>

          <!-- Array type picker -->
          <Border Classes="type-picker" x:Name="ArrayTypePickerPanel" IsVisible="False" Margin="0,0,0,10">
            <StackPanel Spacing="8">
              <DockPanel>
                <TextBlock Classes="field-label" Text="SELECT ITEM TYPE"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <Button Classes="array-remove-btn" Content="✕" HorizontalAlignment="Right"
                        Click="OnCancelArrayAdd" Foreground="#415A77"/>
              </DockPanel>
              <WrapPanel Orientation="Horizontal">
                <Button Classes="type-choice-btn" Content="int"    Tag="int"    Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="float"  Tag="float"  Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="bool"   Tag="bool"   Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="byte"   Tag="byte"   Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="string" Tag="string" Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="name"   Tag="name"   Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="struct" Tag="struct" Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
                <Button Classes="type-choice-btn" Content="enum"   Tag="enum"   Click="OnArrayTypeChosen" Margin="0,0,6,6"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <ItemsControl ItemsSource="{Binding Children}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:NodeViewModel">
                <Border Padding="0,5" BorderBrush="#1B263B" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="Auto,6,Auto,12,*,8,Auto,4,Auto">
                    <!-- Badge -->
                    <Border Grid.Column="0" Classes="badge" VerticalAlignment="Center"
                            IsVisible="{Binding ShowBadgeNonIni}"
                            Classes.badge-int="{Binding TypeHint,    Converter={x:Static vm:TypeHintConverters.IsInt}}"
                            Classes.badge-float="{Binding TypeHint,  Converter={x:Static vm:TypeHintConverters.IsFloat}}"
                            Classes.badge-bool="{Binding TypeHint,   Converter={x:Static vm:TypeHintConverters.IsBool}}"
                            Classes.badge-string="{Binding TypeHint, Converter={x:Static vm:TypeHintConverters.IsString}}"
                            Classes.badge-byte="{Binding TypeHint,   Converter={x:Static vm:TypeHintConverters.IsByte}}"
                            Classes.badge-struct="{Binding IsStruct}"
                            Classes.badge-array="{Binding IsArray}"
                            Classes.badge-enum="{Binding IsEnum}">
                      <TextBlock Text="{Binding TypeHint}" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <!-- FName badge alternative -->
                    <Border Grid.Column="0" Classes="badge badge-fname" VerticalAlignment="Center"
                            IsVisible="{Binding ShowBadgeIni}">
                      <TextBlock Text="fname" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <!-- Entry label -->
                    <TextBlock Grid.Column="2" Classes="prop-label"
                               Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                    <!-- Inline value preview for primitive array items -->
                    <TextBlock Grid.Column="4" VerticalAlignment="Center"
                               IsVisible="{Binding IsPrimitive}"
                               Text="{Binding EditValue}"
                               Foreground="#778DA9" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="6" Classes="array-remove-btn" Content="⧉"
                            Tag="{Binding}" Click="OnDuplicateItemClick" Foreground="#415A77"/>
                    <Button Grid.Column="8" Classes="array-remove-btn" Content="✕"
                            Tag="{Binding}" Click="OnRemoveItemClick"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Panel>
</UserControl>
