<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Palette:
      #0D1B2A  deep navy      (window bg)
      #1B263B  dark steel     (panel bg)
      #415A77  mid steel      (borders, dividers)
      #778DA9  slate          (labels, muted text)
      #E0E1DD  off-white      (primary text)
  -->

  <!--  Global font ──────────────────────────────────────────────────── -->
  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
    <Setter Property="Foreground"  Value="#E0E1DD"/>
  </Style>
  <Style Selector="TextBox">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
  </Style>

  <!--  Window ───────────────────────────────────────────────────────── -->
  <Style Selector="Window">
    <Setter Property="Background" Value="#0D1B2A"/>
  </Style>

  <!--  Toolbar ──────────────────────────────────────────────────────── -->
  <Style Selector="Border.toolbar">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>

  <Style Selector="Button.toolbar-btn">
    <Setter Property="Background"   Value="#1B263B"/>
    <Setter Property="Foreground"   Value="#E0E1DD"/>
    <Setter Property="BorderBrush"  Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"      Value="12,6"/>
    <Setter Property="FontSize"     Value="12"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Cursor"       Value="Hand"/>
  </Style>
  <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
  </Style>
  <Style Selector="Button.toolbar-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#778DA9"/>
  </Style>
  <Style Selector="Button.toolbar-btn.accent">
    <Setter Property="Background"  Value="#415A77"/>
    <Setter Property="Foreground"  Value="#E0E1DD"/>
    <Setter Property="BorderBrush" Value="#778DA9"/>
  </Style>
  <Style Selector="Button.toolbar-btn.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#778DA9"/>
  </Style>

  <!--  Panel headers ────────────────────────────────────────────────── -->
  <Style Selector="Border.panel-header">
    <Setter Property="Background" Value="#0D1B2A"/>
    <Setter Property="Padding"    Value="12,7"/>
  </Style>
  <Style Selector="TextBlock.panel-label">
    <Setter Property="Foreground"    Value="#415A77"/>
    <Setter Property="FontSize"      Value="10"/>
    <Setter Property="FontWeight"    Value="Bold"/>
    <Setter Property="LetterSpacing" Value="2"/>
  </Style>

  <!--  TreeView ─────────────────────────────────────────────────────── -->
  <Style Selector="TreeView">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="4"/>
  </Style>
  <Style Selector="TreeViewItem">
    <Setter Property="Padding"  Value="2,2"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>
  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>

  <!--  Type badges ──────────────────────────────────────────────────── -->
<Style Selector="Border.badge">
    <Setter Property="Padding"           Value="5,2"/>
    <Setter Property="CornerRadius"      Value="3"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Background"        Value="#243447"/>
</Style>
<Style Selector="Border.badge TextBlock">
    <Setter Property="FontSize"           Value="11"/>
    <Setter Property="FontWeight"         Value="Bold"/>
    <Setter Property="VerticalAlignment"  Value="Center"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="TextAlignment"      Value="Center"/>
    <Setter Property="LineHeight"         Value="15"/>
</Style>

  <!-- Uniform badge colors : every badge variant uses identical background. -->
  <Style Selector="Border.badge-int"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-float"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-bool"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-string"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-byte"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-name"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-struct"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-array"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-enum"><Setter Property="Background" Value="#243447"/></Style>
  <Style Selector="Border.badge-fname"><Setter Property="Background" Value="#243447"/></Style>

  <!-- All badge text uses identical color -->
  <Style Selector="Border.badge TextBlock"><Setter Property="Foreground" Value="#A0BAD0"/></Style>

  <!--  Expander glyph ──────────────────────────────────────────────────── -->
  <Style Selector="TextBlock.expander-glyph">
    <Setter Property="FontSize"   Value="30"/>
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="Width"      Value="80"/>
    <Setter Property="TextAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Cursor"     Value="Hand"/>
  </Style>
  <Style Selector="TextBlock.expander-glyph:pointerover">
    <Setter Property="Foreground" Value="#778DA9"/>
  </Style>

  <!--  Log panel ────────────────────────────────────────────────────────── -->
  <Style Selector="Border.log-panel">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="BorderBrush"     Value="#1B263B"/>
    <Setter Property="BorderThickness" Value="0,1,0,0"/>
  </Style>
  <Style Selector="Border.log-header">
    <Setter Property="Background" Value="#0a1520"/>
    <Setter Property="Padding"    Value="12,5"/>
  </Style>
  <Style Selector="TextBlock.log-entry">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
    <Setter Property="FontSize"   Value="13"/>
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="Padding"    Value="12,1"/>
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.log-entry.error">
    <Setter Property="Foreground" Value="#8a4a4a"/>
  </Style>
  <Style Selector="Button.log-clear-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#415A77"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize"        Value="10"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Padding"         Value="6,2"/>
  </Style>
  <Style Selector="Button.log-clear-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#778DA9"/>
  </Style>

  <!--  Array buttons ────────────────────────────────────────────────────── -->
  <Style Selector="Button.array-remove-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#415A77"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="4,0"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.array-remove-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#ff5a5a"/>
  </Style>

  <Style Selector="Button.add-item-btn">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="8,4"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="CornerRadius"    Value="3"/>
    <Setter Property="Cursor"          Value="Hand"/>
  </Style>
  <Style Selector="Button.add-item-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>

  <!--  Add item dialog ──────────────────────────────────────────────── -->
  <Style Selector="Border.type-picker">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="4"/>
    <Setter Property="Padding"         Value="12"/>
  </Style>
  <Style Selector="Button.type-choice-btn">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="10,6"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="CornerRadius"    Value="3"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
  </Style>
  <Style Selector="Button.type-choice-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>

  <!--  About dialog link button ────────────────────────────────────────── -->
  <Style Selector="Button.about-link-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="0"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FontFamily"      Value="'Cascadia Code','Consolas',monospace"/>
  </Style>
  <Style Selector="Button.about-link-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>


  <!--  Search bar ──────────────────────────────────────────────────────── -->
  <Style Selector="Border.search-bar">
    <Setter Property="Background"      Value="#0a1520"/>
    <Setter Property="BorderBrush"     Value="#1B263B"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="4"/>
    <Setter Property="Padding"         Value="8,3"/>
    <Setter Property="Height"          Value="28"/>
  </Style>
  <Style Selector="TextBlock.search-icon">
    <Setter Property="Foreground"        Value="#415A77"/>
    <Setter Property="FontSize"          Value="12"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin"            Value="0,0,8,0"/>
  </Style>
  <Style Selector="TextBox.search-input">
    <Setter Property="Background"        Value="Transparent"/>
    <Setter Property="BorderThickness"   Value="0"/>
    <Setter Property="Foreground"        Value="#E0E1DD"/>
    <Setter Property="FontSize"          Value="12"/>
    <Setter Property="Padding"           Value="0"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="MinHeight"         Value="0"/>
  </Style>
  <!-- Remove the default focus border from the search box -->
  <Style Selector="TextBox.search-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderBrush"     Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="TextBox.search-input /template/ Border#PART_BorderElement">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderBrush"     Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="TextBox.search-input:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderBrush"     Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

</Styles>
