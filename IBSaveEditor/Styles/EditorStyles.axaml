<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Palette:
      #0D1B2A  deep navy      (window bg)
      #1B263B  dark steel     (panel bg)
      #415A77  mid steel      (borders, dividers)
      #778DA9  slate          (labels, muted text)
      #E0E1DD  off-white      (primary text)
  -->

  <!-- ── Global font ────────────────────────────────────────────────────── -->
  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
    <Setter Property="Foreground"  Value="#E0E1DD"/>
  </Style>
  <Style Selector="TextBox">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
  </Style>

  <!-- ── Window ─────────────────────────────────────────────────────────── -->
  <Style Selector="Window">
    <Setter Property="Background" Value="#0D1B2A"/>
  </Style>

  <!-- ── Toolbar ────────────────────────────────────────────────────────── -->
  <Style Selector="Border.toolbar">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>

  <Style Selector="Button.toolbar-btn">
    <Setter Property="Background"   Value="#1B263B"/>
    <Setter Property="Foreground"   Value="#E0E1DD"/>
    <Setter Property="BorderBrush"  Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"      Value="12,6"/>
    <Setter Property="FontSize"     Value="12"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Cursor"       Value="Hand"/>
  </Style>
  <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
  </Style>
  <Style Selector="Button.toolbar-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#778DA9"/>
  </Style>
  <Style Selector="Button.toolbar-btn.accent">
    <Setter Property="Background"  Value="#415A77"/>
    <Setter Property="Foreground"  Value="#E0E1DD"/>
    <Setter Property="BorderBrush" Value="#778DA9"/>
  </Style>
  <Style Selector="Button.toolbar-btn.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#778DA9"/>
  </Style>

  <!-- ── Panel headers ──────────────────────────────────────────────────── -->
  <Style Selector="Border.panel-header">
    <Setter Property="Background" Value="#0D1B2A"/>
    <Setter Property="Padding"    Value="12,7"/>
  </Style>
  <Style Selector="TextBlock.panel-label">
    <Setter Property="Foreground"    Value="#415A77"/>
    <Setter Property="FontSize"      Value="10"/>
    <Setter Property="FontWeight"    Value="Bold"/>
    <Setter Property="LetterSpacing" Value="2"/>
  </Style>

  <!-- ── TreeView ───────────────────────────────────────────────────────── -->
  <Style Selector="TreeView">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="4"/>
  </Style>
  <Style Selector="TreeViewItem">
    <Setter Property="Padding"  Value="2,2"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>
  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#1B263B"/>
  </Style>

  <!-- ── Type badges ────────────────────────────────────────────────────── -->
  <Style Selector="Border.badge">
    <Setter Property="Padding"            Value="4,1"/>
    <Setter Property="CornerRadius"       Value="3"/>
    <Setter Property="VerticalAlignment"  Value="Center"/>
  </Style>
  <Style Selector="Border.badge TextBlock">
    <Setter Property="FontSize"   Value="9"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <!-- Palette-matched badge colors
       int    : slate tint   #415A77 bg, #E0E1DD text
       float  : mid-slate    #415A77 bg, #778DA9 text (italic feel)
       bool   : deep navy+   #1B263B bg, #778DA9 text
       string : dark steel   #1B263B bg, #E0E1DD text
       byte   : like int but dimmer
       name   : like string
       struct : accent navy  #0D1B2A bg, #778DA9 border+text
       array  : like struct but brighter border
       enum   : mid-steel    #415A77 bg, #0D1B2A text
  -->
  <Style Selector="Border.badge-int">    <Setter Property="Background" Value="#415A77"/> </Style>
  <Style Selector="Border.badge-int TextBlock">    <Setter Property="Foreground" Value="#E0E1DD"/> </Style>
  <Style Selector="Border.badge-float">  <Setter Property="Background" Value="#2d4259"/> </Style>
  <Style Selector="Border.badge-float TextBlock">  <Setter Property="Foreground" Value="#aec4d6"/> </Style>
  <Style Selector="Border.badge-bool">   <Setter Property="Background" Value="#1B263B"/> <Setter Property="BorderBrush" Value="#415A77"/> <Setter Property="BorderThickness" Value="1"/> </Style>
  <Style Selector="Border.badge-bool TextBlock">   <Setter Property="Foreground" Value="#778DA9"/> </Style>
  <Style Selector="Border.badge-string"> <Setter Property="Background" Value="#1B263B"/> </Style>
  <Style Selector="Border.badge-string TextBlock"> <Setter Property="Foreground" Value="#E0E1DD"/> </Style>
  <Style Selector="Border.badge-byte">   <Setter Property="Background" Value="#263445"/> </Style>
  <Style Selector="Border.badge-byte TextBlock">   <Setter Property="Foreground" Value="#9db8cc"/> </Style>
  <Style Selector="Border.badge-name">   <Setter Property="Background" Value="#1e2e3e"/> </Style>
  <Style Selector="Border.badge-name TextBlock">   <Setter Property="Foreground" Value="#c0d4e0"/> </Style>
  <Style Selector="Border.badge-struct"> <Setter Property="Background" Value="#0D1B2A"/> <Setter Property="BorderBrush" Value="#415A77"/> <Setter Property="BorderThickness" Value="1"/> </Style>
  <Style Selector="Border.badge-struct TextBlock"> <Setter Property="Foreground" Value="#778DA9"/> </Style>
  <Style Selector="Border.badge-array">  <Setter Property="Background" Value="#0D1B2A"/> <Setter Property="BorderBrush" Value="#778DA9"/> <Setter Property="BorderThickness" Value="1"/> </Style>
  <Style Selector="Border.badge-array TextBlock">  <Setter Property="Foreground" Value="#778DA9"/> </Style>
  <Style Selector="Border.badge-enum">   <Setter Property="Background" Value="#415A77"/> </Style>
  <Style Selector="Border.badge-enum TextBlock">   <Setter Property="Foreground" Value="#0D1B2A"/> </Style>

  <!-- ── Property editor inputs ─────────────────────────────────────────── -->
  <Style Selector="TextBox.prop-input">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="Foreground"      Value="#E0E1DD"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="3"/>
    <Setter Property="Padding"         Value="8,5"/>
    <Setter Property="FontSize"        Value="12"/>
  </Style>
  <Style Selector="TextBox.prop-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="#778DA9"/>
  </Style>
  <Style Selector="NumericUpDown.prop-input">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="Foreground"      Value="#E0E1DD"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontSize"        Value="12"/>
  </Style>

  <Style Selector="TextBlock.prop-label">
    <Setter Property="Foreground" Value="#778DA9"/>
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <Style Selector="TextBlock.field-label">
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="FontSize"   Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1"/>
    <Setter Property="Margin"     Value="0,0,0,4"/>
  </Style>

  <!-- ── Dividers ───────────────────────────────────────────────────────── -->
  <Style Selector="Border.divider">
    <Setter Property="Background" Value="#1B263B"/>
    <Setter Property="Height"     Value="1"/>
  </Style>
  <Style Selector="Border.v-divider">
    <Setter Property="Background" Value="#1B263B"/>
    <Setter Property="Width"      Value="1"/>
  </Style>

  <!-- ── Status bar ─────────────────────────────────────────────────────── -->
  <Style Selector="Border.statusbar">
    <Setter Property="Background" Value="#0D1B2A"/>
    <Setter Property="Padding"    Value="12,4"/>
  </Style>
  <Style Selector="TextBlock.status-text">
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="FontSize"   Value="11"/>
  </Style>

  <!-- ── ScrollBar ──────────────────────────────────────────────────────── -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <!-- ── Expander glyph ────────────────────────────────────────────────────── -->
  <Style Selector="TextBlock.expander-glyph">
    <Setter Property="FontSize"   Value="16"/>
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="Width"      Value="24"/>
    <Setter Property="TextAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Cursor"     Value="Hand"/>
  </Style>
  <Style Selector="TextBlock.expander-glyph:pointerover">
    <Setter Property="Foreground" Value="#778DA9"/>
  </Style>

  <!-- ── Log panel ──────────────────────────────────────────────────────────── -->
  <Style Selector="Border.log-panel">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="BorderBrush"     Value="#1B263B"/>
    <Setter Property="BorderThickness" Value="0,1,0,0"/>
  </Style>
  <Style Selector="Border.log-header">
    <Setter Property="Background" Value="#0a1520"/>
    <Setter Property="Padding"    Value="12,5"/>
  </Style>
  <Style Selector="TextBlock.log-entry">
    <Setter Property="FontFamily" Value="'Cascadia Code','Consolas','Courier New',monospace"/>
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="Foreground" Value="#415A77"/>
    <Setter Property="Padding"    Value="12,1"/>
  </Style>
  <Style Selector="TextBlock.log-entry.error">
    <Setter Property="Foreground" Value="#8a4a4a"/>
  </Style>
  <Style Selector="Button.log-clear-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#415A77"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize"        Value="10"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Padding"         Value="6,2"/>
  </Style>
  <Style Selector="Button.log-clear-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#778DA9"/>
  </Style>

  <!-- ── Array buttons ──────────────────────────────────────────────────────── -->
  <Style Selector="Button.array-remove-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#415A77"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="4,0"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.array-remove-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#ff5a5a"/>
  </Style>

  <Style Selector="Button.add-item-btn">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="8,4"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="CornerRadius"    Value="3"/>
    <Setter Property="Cursor"          Value="Hand"/>
  </Style>
  <Style Selector="Button.add-item-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>

  <!-- ── Add item dialog ────────────────────────────────────────────────── -->
  <Style Selector="Border.type-picker">
    <Setter Property="Background"      Value="#1B263B"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="4"/>
    <Setter Property="Padding"         Value="12"/>
  </Style>
  <Style Selector="Button.type-choice-btn">
    <Setter Property="Background"      Value="#0D1B2A"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderBrush"     Value="#415A77"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="10,6"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="CornerRadius"    Value="3"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
  </Style>
  <Style Selector="Button.type-choice-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#415A77"/>
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>

  <!-- ── About dialog link button ──────────────────────────────────────────── -->
  <Style Selector="Button.about-link-btn">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="#778DA9"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="0"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FontFamily"      Value="'Cascadia Code','Consolas',monospace"/>
  </Style>
  <Style Selector="Button.about-link-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#E0E1DD"/>
  </Style>

</Styles>
